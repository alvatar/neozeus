+fn srgb_to_linear_channel(value: f32) -> f32 {
+    if value <= 0.04045 {
+        value / 12.92
+    } else {
+        ((value + 0.055) / 1.055).powf(2.4)
+    }
+}
+
+fn linear_to_srgb_channel(value: f32) -> f32 {
+    if value <= 0.0031308 {
+        value * 12.92
+    } else {
+        1.055 * value.powf(1.0 / 2.4) - 0.055
+    }
+}
+
+fn premul_srgb_to_linear(pixel: [f32; 4]) -> [f32; 4] {
+    if pixel[3] <= 1e-6 {
+        return [0.0; 4];
+    }
+    let alpha = pixel[3];
+    let separated = [pixel[0] / alpha, pixel[1] / alpha, pixel[2] / alpha];
+    [
+        srgb_to_linear_channel(separated[0]) * alpha,
+        srgb_to_linear_channel(separated[1]) * alpha,
+        srgb_to_linear_channel(separated[2]) * alpha,
+        alpha,
+    ]
+}
+
+fn linear_rgba_to_srgba(pixel: [f32; 4]) -> [f32; 4] {
+    [
+        linear_to_srgb_channel(pixel[0]),
+        linear_to_srgb_channel(pixel[1]),
+        linear_to_srgb_channel(pixel[2]),
+        pixel[3],
+    ]
+}
