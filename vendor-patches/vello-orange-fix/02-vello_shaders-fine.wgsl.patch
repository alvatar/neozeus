 const ALPHA: u32 = 0u;
 const PREMULTIPLIED_ALPHA: u32 = 1u;
-// Premultiplies alpha if not already
+
+fn srgb_to_linear_channel(value: f32) -> f32 {
+    if value <= 0.04045 {
+        return value / 12.92;
+    }
+    return pow((value + 0.055) / 1.055, 2.4);
+}
+
+fn linear_to_srgb_channel(value: f32) -> f32 {
+    if value <= 0.0031308 {
+        return value * 12.92;
+    }
+    return 1.055 * pow(value, 1.0 / 2.4) - 0.055;
+}
+
+fn srgb_to_linear(rgb: vec3f) -> vec3f {
+    return vec3f(
+        srgb_to_linear_channel(rgb.r),
+        srgb_to_linear_channel(rgb.g),
+        srgb_to_linear_channel(rgb.b),
+    );
+}
+
+fn linear_to_srgb(rgb: vec3f) -> vec3f {
+    return vec3f(
+        linear_to_srgb_channel(rgb.r),
+        linear_to_srgb_channel(rgb.g),
+        linear_to_srgb_channel(rgb.b),
+    );
+}
+
+fn premul_srgb_to_linear(pixel: vec4f) -> vec4f {
+    if pixel.a <= 1e-6 {
+        return vec4f(0.0);
+    }
+    let separated = pixel.rgb / pixel.a;
+    let linear = srgb_to_linear(separated);
+    return vec4f(linear * pixel.a, pixel.a);
+}
+
+fn linear_rgba_to_srgba(pixel: vec4f) -> vec4f {
+    return vec4f(linear_to_srgb(pixel.rgb), pixel.a);
+}
+
+// Premultiplies alpha if not already and converts sampled sRGB-like bytes into linear-light premul.
