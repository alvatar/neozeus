#!/usr/bin/env bash
set -euo pipefail

script_dir=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
repo_root=$(cd -- "$script_dir/.." && pwd)

cd "$repo_root"
cargo build --release --bin neozeus-msg
mkdir -p "$HOME/.local/bin"
install -m 0755 "$repo_root/target/release/neozeus-msg" "$HOME/.local/bin/neozeus-msg"
printf 'installed %s\n' "$HOME/.local/bin/neozeus-msg"
